# Copy this file to `.env` and fill in real values before deploying.
# `docker compose` reads `.env` automatically.

# ---- Database --------------------------------------------------------------
POSTGRES_USER=springfield
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=springfield

# ---- Auth / JWT secrets ----------------------------------------------------
# Generate strong random values, e.g.:  openssl rand -hex 32
JWT_SECRET=change-me-access-token-secret
JWT_REFRESH_SECRET=change-me-refresh-token-secret
# Optional legacy fallback used if the JWT secrets above are unset.
SESSION_SECRET=

# ---- App behaviour ---------------------------------------------------------
# Set to `true` for the FIRST boot to load demo data (tenant, users, classes,
# students, etc.). Set back to `false` afterwards to avoid re-seeding.
SEED_ON_START=false
LOG_LEVEL=info

# ---- Networking ------------------------------------------------------------
# Host port the web (nginx) container is published on.
WEB_PORT=80
